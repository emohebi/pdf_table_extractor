# Azure OpenAI Configuration
# Copy this file to .env and fill in your values
#
# To test your connection:
#   python -m src.main --test-connection --api-key YOUR_KEY --endpoint YOUR_ENDPOINT

# Required: Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-api-key-here

# Required: Your Azure OpenAI endpoint URL
# Format: https://YOUR-RESOURCE-NAME.openai.azure.com
# NOTE: Do NOT include /openai/deployments/... in the URL
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com

# Optional: Model deployment name (default: gpt-4o)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Optional: API version (default: 2024-08-01-preview)
# Other options: 2024-02-15-preview, 2023-12-01-preview
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
